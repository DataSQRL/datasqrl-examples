CREATE TABLE Bolo (
    PRIMARY KEY (`bolo_id`, `last_updated`) NOT ENFORCED,
    WATERMARK FOR `last_updated` AS `last_updated`
) WITH (
    'source.monitor-interval' = '10 min'
) LIKE `testdata/bolo.jsonl`;

CREATE TABLE Driver (
    PRIMARY KEY (`driver_id`, `last_updated`) NOT ENFORCED,
    WATERMARK FOR `last_updated` AS `last_updated` - INTERVAL '0' SECOND
) WITH (
    'source.monitor-interval' = '10 min'
) LIKE `testdata/driver.jsonl`;

CREATE TABLE Vehicle (
    PRIMARY KEY (`vehicle_id`, `last_updated`) NOT ENFORCED,
    WATERMARK FOR `last_updated` AS `last_updated` - INTERVAL '0' SECOND
) WITH (
    'source.monitor-interval' = '10 min'
) LIKE `testdata/vehicle.jsonl`;

CREATE TABLE Warrant (
    PRIMARY KEY (`warrant_id`, `last_updated`) NOT ENFORCED,
    WATERMARK FOR `last_updated` AS `last_updated` - INTERVAL '0' SECOND
) WITH (
    'source.monitor-interval' = '10 min'
) LIKE `testdata/warrant.jsonl`;
