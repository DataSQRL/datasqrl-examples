{
  "version": "1",
  "enabled-engines": ["flink", "kafka", "postgres", "vertx"],
  "script": {
    "main": "scheduled-batch.sqrl"
  },
  "engines": {
    "flink": {
      "config": {
        "execution.runtime-mode": "BATCH",
        "security.delegation.tokens.enabled": false
      },
      "deployment": {
        "jobmanager-size": "small",
        "taskmanager-size": "small",
        "taskmanager-count": 1,
        "schedule": {
          "cron": "*/15 * * * *",
          "timezone": "UTC"
        }
      }
    }
  }
}
